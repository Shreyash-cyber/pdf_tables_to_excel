with header_col1:
    st.markdown(
        f"""
        <div class="header-bar" style="margin-left: -2rem; margin-right: -2rem; padding: 1.5rem 2rem;">
            <div class="header-left">
                <div class="logo-container">
                    <img src="data:image/png;base64,{logo_b64}" style="height: 50px; object-fit: contain;">
                </div>
                <div>
                    <div class="header-title">PDF to Excel</div>
                    <div class="header-subtitle">Table Extraction Engine</div>
