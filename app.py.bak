# ══════════════════════════════════════════════════════════════════════════
#  Output Format Selection (Right Corner)
# ══════════════════════════════════════════════════════════════════════════

with header_col2:
    st.markdown(
        """
        <div class="format-card" style="margin-top: 1rem; margin-right: -2rem; margin-left: auto; width: 280px;">
        <div class="format-card-title">Output Format</div>
        """,
        unsafe_allow_html=True,
    )
    
    selected_format = st.radio(
        "Select output format:",
        options=["excel", "csv", "json", "markdown"],
        format_func=lambda x: {
            "excel": "Excel (XLSX)",
            "csv": "CSV (ZIP)",
            "json": "JSON",
            "markdown": "Markdown"
        }[x],
        label_visibility="collapsed",
    )
    
    st.markdown("</div>", unsafe_allow_html=True)

